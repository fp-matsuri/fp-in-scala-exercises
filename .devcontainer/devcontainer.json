{
  "name": "FP in Scala Exercises",
  "image": "ghcr.io/fp-matsuri/fp-in-scala-exercises/devcontainer:bc1ba606343c",
  "remoteUser": "vscode",
  "containerEnv": {
    "MISE_TRUSTED_CONFIG_PATHS": "/workspaces"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "betterthantomorrow.calva",
        "clj-kondo.clj-kondo",
        "scalameta.metals",
        "haskell.haskell",
        "ocamllabs.ocaml-platform",
        "usernamehw.errorlens"
      ]
    }
  }
}
